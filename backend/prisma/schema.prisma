model companies {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  group_id                  String                      @db.Uuid
  parent_id                 String?                     @db.Uuid
  name                      String                      @db.VarChar(150)
  legal_name                String?                     @db.VarChar(200)
  code                      String?                     @unique @db.VarChar(50)
  ice                       String?                     @db.VarChar(50)
  tax_id                    String?                     @db.VarChar(50)
  rc                        String?                     @db.VarChar(50)
  cnss                      String?                     @db.VarChar(50)
  patente                   String?                     @db.VarChar(50)
  address                   String?
  city                      String?                     @db.VarChar(100)
  region                    String?                     @db.VarChar(100)
  country                   String?                     @default("Maroc") @db.VarChar(100)
  latitude                  Decimal?                    @db.Decimal(10, 7)
  longitude                 Decimal?                    @db.Decimal(10, 7)
  responsible_id            String?                     @db.Uuid
  status                    company_status_enum         @default(ACTIVE)
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                DateTime                    @default(now()) @db.Timestamp(6)
  deleted_at                DateTime?                   @db.Timestamp(6)
  country_id                String?                     @db.VarChar(20)
  region_id                 String?                     @db.VarChar(50)
  city_id                   String?                     @db.VarChar(80)
  charges                   charges[]
  groups                    groups                      @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_companies_group")
  companies                 companies?                  @relation("companiesTocompanies", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_companies_parent")
  other_companies           companies[]                 @relation("companiesTocompanies")
  users                     users?                      @relation(fields: [responsible_id], references: [id], onUpdate: NoAction, map: "fk_companies_responsible")
  company_legal_identifiers company_legal_identifiers[]
  factories                 factories[]
  farms                     farms[]
  personnel                 personnel[]
  stations                  stations[]
  vehicles                  vehicles[]

  @@index([group_id], map: "idx_companies_group_id")
  @@index([parent_id], map: "idx_companies_parent_id")
  @@index([status], map: "idx_companies_status")
  @@index([city_id], map: "idx_companies_city_id")
  @@index([country_id], map: "idx_companies_country_id")
  @@index([region_id], map: "idx_companies_region_id")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model agricultural_projects {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id            String              @db.Uuid
  plot_id            String?             @db.Uuid
  product_id         String              @db.Uuid
  variety_id         String?             @db.Uuid
  name               String              @db.VarChar(150)
  season             String?             @db.VarChar(100)
  plant_count        Int                 @default(0)
  active_plant_count Int?
  surface_ha         Decimal?            @db.Decimal(12, 2)
  start_date         DateTime?           @db.Date
  expected_end_date  DateTime?           @db.Date
  end_date           DateTime?           @db.Date
  responsible_id     String?             @db.Uuid
  status             project_status_enum @default(PREPARATION)
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  updated_at         DateTime            @default(now()) @db.Timestamp(6)
  deleted_at         DateTime?           @db.Timestamp(6)
  farms              farms               @relation(fields: [farm_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_agricultural_projects_farm")
  plots              plots?              @relation(fields: [plot_id], references: [id], onUpdate: NoAction, map: "fk_agricultural_projects_plot")
  products           products            @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_agricultural_projects_product")
  users              users?              @relation(fields: [responsible_id], references: [id], onUpdate: NoAction, map: "fk_agricultural_projects_responsible")
  product_varieties  product_varieties?  @relation(fields: [variety_id], references: [id], onUpdate: NoAction, map: "fk_agricultural_projects_variety")
  charges            charges[]
  farm_shipments     farm_shipments[]
  harvests           harvests[]
  plantations        plantations[]
  productions        productions[]
  treatments         treatments[]

  @@index([farm_id], map: "idx_agricultural_projects_farm_id")
  @@index([plot_id], map: "idx_agricultural_projects_plot_id")
  @@index([product_id], map: "idx_agricultural_projects_product_id")
  @@index([status], map: "idx_agricultural_projects_status")
}

model alerts {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String            @db.VarChar(200)
  message        String
  level          alert_level_enum  @default(INFO)
  entity_type    entity_type_enum?
  entity_id      String?           @db.Uuid
  assigned_to_id String?           @db.Uuid
  is_resolved    Boolean           @default(false)
  resolved_at    DateTime?         @db.Timestamp(6)
  created_at     DateTime          @default(now()) @db.Timestamp(6)
  users          users?            @relation(fields: [assigned_to_id], references: [id], onUpdate: NoAction, map: "fk_alerts_assigned_to")

  @@index([assigned_to_id], map: "idx_alerts_assigned_to")
  @@index([is_resolved], map: "idx_alerts_is_resolved")
  @@index([level], map: "idx_alerts_level")
}

model audit_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?  @db.Uuid
  action      String   @db.VarChar(150)
  entity_type String   @db.VarChar(150)
  entity_id   String?  @db.Uuid
  old_value   Json?
  new_value   Json?
  ip_address  String?  @db.VarChar(100)
  user_agent  String?
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       users?   @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_audit_logs_user")

  @@index([created_at], map: "idx_audit_logs_created_at")
  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([user_id], map: "idx_audit_logs_user_id")
}

